{
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "prod": "docker compose up --build",
    "down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "seed": "docker compose exec server node src/scripts/seed.js"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
